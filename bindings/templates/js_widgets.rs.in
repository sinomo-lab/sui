#[napi(js_name = "Slider")]
pub fn js_slider(
    env: Env,
    name: Either4<ClassInstance<'_, JsState>, String, f64, bool>,
    value: Option<Either3<ClassInstance<'_, JsState>, f64, bool>>,
    min: Option<f64>,
    max: Option<f64>,
    step: Option<f64>,
    on_change: Option<Function<'_, (f64,), ()>>,
) -> Result<JsWidget> {
    let action = on_change
        .map(|callback| {
            let env = JsEnvHandle::from_env(env);
            let callback = callback.create_ref()?;
            Ok::<_, Error>(BindingNumberAction::new(move |value| {
                let env = env.to_env();
                let callback = callback
                    .borrow_back(&env)
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))?;
                callback
                    .call((value,))
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))
            }))
        })
        .transpose()?;
    Ok(JsWidget::from_binding(BindingWidget::slider(
        binding_text_from_js(name),
        value
            .map(binding_number_from_js)
            .unwrap_or(BindingNumber::Static(0.0)),
        min.unwrap_or(0.0),
        max.unwrap_or(1.0),
        step.unwrap_or(0.01),
        action,
    )))
}

#[napi(js_name = "NumberInput")]
pub fn js_number_input(
    env: Env,
    name: Either4<ClassInstance<'_, JsState>, String, f64, bool>,
    value: Option<Either3<ClassInstance<'_, JsState>, f64, bool>>,
    min: Option<f64>,
    max: Option<f64>,
    step: Option<f64>,
    precision: Option<u32>,
    on_change: Option<Function<'_, (f64,), ()>>,
) -> Result<JsWidget> {
    let action = on_change
        .map(|callback| {
            let env = JsEnvHandle::from_env(env);
            let callback = callback.create_ref()?;
            Ok::<_, Error>(BindingNumberAction::new(move |value| {
                let env = env.to_env();
                let callback = callback
                    .borrow_back(&env)
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))?;
                callback
                    .call((value,))
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))
            }))
        })
        .transpose()?;
    Ok(JsWidget::from_binding(BindingWidget::number_input(
        binding_text_from_js(name),
        value
            .map(binding_number_from_js)
            .unwrap_or(BindingNumber::Static(0.0)),
        min.unwrap_or(f64::NEG_INFINITY),
        max.unwrap_or(f64::INFINITY),
        step.unwrap_or(1.0),
        precision.unwrap_or(2) as usize,
        action,
    )))
}

#[napi(js_name = "Select")]
pub fn js_select(
    env: Env,
    name: Either4<ClassInstance<'_, JsState>, String, f64, bool>,
    options: Vec<String>,
    selected: Option<Either3<ClassInstance<'_, JsState>, f64, bool>>,
    placeholder: Option<String>,
    on_change: Option<Function<'_, (u32, String), ()>>,
) -> Result<JsWidget> {
    let action = on_change
        .map(|callback| {
            let env = JsEnvHandle::from_env(env);
            let callback = callback.create_ref()?;
            Ok::<_, Error>(BindingSelectAction::new(move |index, value| {
                let env = env.to_env();
                let callback = callback
                    .borrow_back(&env)
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))?;
                callback
                    .call((index as u32, value))
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))
            }))
        })
        .transpose()?;
    Ok(JsWidget::from_binding(BindingWidget::select(
        binding_text_from_js(name),
        options,
        selected.map(binding_number_from_js),
        placeholder,
        action,
    )))
}

