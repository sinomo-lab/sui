#[napi(js_name = "TextSpan")]
#[derive(Debug, Clone)]
pub struct JsTextSpan {
    inner: BindingTextSpan,
}

#[napi]
impl JsTextSpan {
    #[napi(constructor)]
    pub fn new(
        text: String,
        color: Option<&JsColor>,
        font_size: Option<f64>,
        line_height: Option<f64>,
        font: Option<&JsFontHandle>,
        weight: Option<u32>,
        style: Option<String>,
        stretch: Option<String>,
    ) -> Result<Self> {
        Ok(Self {
            inner: BindingTextSpan::new(
                text,
                js_text_style(
                    color,
                    font_size,
                    line_height,
                    font,
                    weight,
                    style.as_deref(),
                    stretch.as_deref(),
                )?,
            ),
        })
    }

    #[napi(getter)]
    pub fn text(&self) -> String {
        self.inner.text.clone()
    }
}

#[napi(js_name = "StatusBarSegment")]
#[derive(Debug, Clone)]
pub struct JsStatusBarSegment {
