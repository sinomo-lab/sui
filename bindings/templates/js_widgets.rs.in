#[napi(js_name = "TreeItem")]
#[derive(Debug, Clone)]
pub struct JsTreeItem {
    inner: BindingTreeItem,
}

#[napi]
impl JsTreeItem {
    #[napi(constructor)]
    pub fn new(
        label: String,
        detail: Option<String>,
        expanded: Option<bool>,
        disabled: Option<bool>,
        children: Option<Array<'_>>,
    ) -> Result<Self> {
        let children = children
            .as_ref()
            .map(extract_tree_items)
            .transpose()?
            .unwrap_or_default();
        Ok(Self {
            inner: BindingTreeItem::new(
                label,
                detail,
                expanded.unwrap_or(false),
                disabled.unwrap_or(false),
                children,
            ),
        })
    }
}

