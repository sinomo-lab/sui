pub fn py_dialog(
    title: &Bound<'_, PyAny>,
    content: PyRef<'_, PyWidget>,
    shown: Option<&Bound<'_, PyAny>>,
) -> PyResult<PyWidget> {
    let shown = shown
        .map(binding_bool_from_py)
        .transpose()?
        .unwrap_or(BindingBool::Static(true));
    Ok(PyWidget::from_binding(BindingWidget::dialog(
        binding_text_from_py(title)?,
        content.binding_widget()?,
        shown,
    )))
}

#[pyfunction(name = "Padding")]
#[pyo3(signature = (child, padding=0.0, top=None, right=None, bottom=None, fill_child_width=false, fill_child_height=false))]
pub fn py_padding(
    child: PyRef<'_, PyWidget>,
    padding: f32,
    top: Option<f32>,
    right: Option<f32>,
    bottom: Option<f32>,
    fill_child_width: bool,
    fill_child_height: bool,
) -> PyResult<PyWidget> {
    let insets = sui_crate::Insets {
        left: padding.max(0.0),
        top: top.unwrap_or(padding).max(0.0),
        right: right.unwrap_or(padding).max(0.0),
        bottom: bottom.unwrap_or(top.unwrap_or(padding)).max(0.0),
    };
    Ok(PyWidget::from_binding(BindingWidget::padding(
        child.binding_widget()?,
        insets,
        fill_child_width,
        fill_child_height,
    )))
}

