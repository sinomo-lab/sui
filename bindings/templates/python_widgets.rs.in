        BindingSelectAction::new(move |index, value| {
            Python::attach(|py| {
                callback
                    .call1(py, (index, value))
                    .map(|_| ())
                    .map_err(|error| ForeignCallbackFailure::new(error.to_string()))
            })
        })
    });
    let on_close = on_close.map(|callback| {
        BindingSelectAction::new(move |index, value| {
            Python::attach(|py| {
                callback
                    .call1(py, (index, value))
                    .map(|_| ())
