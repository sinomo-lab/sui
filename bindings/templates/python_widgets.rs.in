#[pyclass(name = "TextSpan", module = "sui", skip_from_py_object)]
#[derive(Debug, Clone)]
pub struct PyTextSpan {
    inner: BindingTextSpan,
}

#[pymethods]
impl PyTextSpan {
    #[new]
    #[pyo3(signature = (text, color=None, font_size=None, line_height=None, font=None, weight=None, style=None, stretch=None))]
    pub fn new(
        text: String,
        color: Option<PyColor>,
        font_size: Option<f32>,
        line_height: Option<f32>,
        font: Option<PyRef<'_, PyFontHandle>>,
        weight: Option<u16>,
        style: Option<&str>,
        stretch: Option<&str>,
    ) -> PyResult<Self> {
        Ok(Self {
            inner: BindingTextSpan::new(
                text,
                py_text_style(color, font_size, line_height, font, weight, style, stretch)?,
            ),
        })
    }

    #[getter]
    pub fn text(&self) -> &str {
        &self.inner.text
    }

    fn __repr__(&self) -> String {
        format!("TextSpan({:?})", self.inner.text)
    }
}

